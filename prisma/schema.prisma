generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  TEACHER
  MODERATOR
  SUPERUSER
}

enum RecordingVisibility {
  PUBLIC
  ASSIGNMENT_ONLY
}

enum UiLanguage {
  EN
  HE
}

enum WorkType {
  TORAH
  NEVIIM
  KETUVIM
}

enum RecordingSource {
  UPLOAD
  BROWSER_RECORDING
}

enum RecordingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELED
}

enum EntitlementSource {
  PURCHASE
  COUPON
  ADMIN_GRANT
}

enum NotificationChannel {
  IN_APP
}

enum NotificationEventType {
  CONTACT_SUBMISSION
}

enum TokenizationEventType {
  MODERATION_APPROVED
  MODERATION_REJECTED
  ASSIGNMENT_CREATED
  ASSIGNMENT_UPDATED
  ASSIGNMENT_DELETED
}

enum TeacherAccessSource {
  FREE
  COUPON
  STRIPE
}

enum TeacherAccessStatus {
  ACTIVE
  CANCELED
}

model User {
  id                 String                 @id @default(cuid())
  name               String?
  email              String?                @unique
  emailVerified      DateTime?
  image              String?
  role               Role                   @default(USER)
  preferredLanguage  UiLanguage             @default(EN)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  accounts           Account[]
  sessions           Session[]
  recordings         Recording[]
  votes              Vote[]
  moderationActions  ModerationDecision[]   @relation("ModeratorActions")
  approvedRecordings Recording[]            @relation("RecordingApprovals")
  teacherGroups      ClassGroup[]           @relation("TeacherGroups")
  classEnrollments   ClassEnrollment[]      @relation("StudentEnrollments")
  sentInvites        TeacherInvite[]        @relation("TeacherInvites")
  acceptedInvites    TeacherInvite[]        @relation("AcceptedTeacherInvites")
  directTeacherLinks TeacherStudentLink[]   @relation("DirectTeacherLinks")
  directStudentLinks TeacherStudentLink[]   @relation("DirectStudentLinks")
  createdAssignments PracticeAssignment[]   @relation("TeacherAssignments")
  playbackAsTeacher  PlaybackEvent[]        @relation("PlaybackTeacher")
  playbackEvents     PlaybackEvent[]
  createdCoupons     Coupon[]               @relation("CouponCreators")
  purchases          RecordingPurchase[]
  entitlements       RecordingEntitlement[]
  tokenLedgerEntries TokenLedgerEntry[]     @relation("TokenRecipient")
  contactMessages    ContactMessage[]
  CouponRedemption   CouponRedemption[]
  teacherAccessSubscription TeacherAccessSubscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Work {
  id        String    @id @default(cuid())
  slug      String    @unique
  titleEn   String
  titleHe   String
  kind      WorkType
  books     Book[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Portion   Portion[]
}

model Book {
  id        String    @id @default(cuid())
  workId    String
  work      Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  slug      String
  titleEn   String
  titleHe   String
  chapters  Chapter[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([workId, slug])
}

model Chapter {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  number    Int
  pesukim   Pasuk[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookId, number])
}

model Pasuk {
  id             String          @id @default(cuid())
  chapterId      String
  chapter        Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  number         Int
  ref            String          @unique
  hebrewText     String?
  englishText    String?
  boundaries     PasukBoundary[]
  recordings     Recording[]     @relation("PrimaryPasuk")
  startsRange    Recording[]     @relation("RangeStart")
  endsRange      Recording[]     @relation("RangeEnd")
  playbackEvents PlaybackEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  PortionPasuk   PortionPasuk[]

  @@unique([chapterId, number])
}

model Portion {
  id          String         @id @default(cuid())
  slug        String         @unique
  titleEn     String
  titleHe     String
  workId      String?
  work        Work?          @relation(fields: [workId], references: [id])
  orderedText PortionPasuk[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PortionPasuk {
  id        String  @id @default(cuid())
  portionId String
  pasukId   String
  position  Int
  portion   Portion @relation(fields: [portionId], references: [id], onDelete: Cascade)
  pasuk     Pasuk   @relation(fields: [pasukId], references: [id], onDelete: Cascade)

  @@unique([portionId, position])
  @@unique([portionId, pasukId])
}

model Recording {
  id                       String                 @id @default(cuid())
  userId                   String
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryPasukId           String
  primaryPasuk             Pasuk                  @relation("PrimaryPasuk", fields: [primaryPasukId], references: [id], onDelete: Cascade)
  rangeStartPasukId        String
  rangeStartPasuk          Pasuk                  @relation("RangeStart", fields: [rangeStartPasukId], references: [id], onDelete: Cascade)
  rangeEndPasukId          String
  rangeEndPasuk            Pasuk                  @relation("RangeEnd", fields: [rangeEndPasukId], references: [id], onDelete: Cascade)
  source                   RecordingSource
  title                    String?
  nussach                  String
  nussachCustom            String?
  storageKey               String
  publicUrl                String
  durationMs               Int
  visibility               RecordingVisibility    @default(PUBLIC)
  status                   RecordingStatus        @default(PENDING_APPROVAL)
  moderationNotes          String?
  submittedAt              DateTime               @default(now())
  approvedAt               DateTime?
  approvedByUserId         String?
  approvedBy               User?                  @relation("RecordingApprovals", fields: [approvedByUserId], references: [id])
  autoAlignmentStatus      String?
  autoAlignmentResult      Json?
  autoAlignmentCompletedAt DateTime?
  boundaries               PasukBoundary[]
  votes                    Vote[]
  moderationHistory        ModerationDecision[]
  assignments              PracticeAssignment[]
  playbackEvents           PlaybackEvent[]
  paywallAsset             PaywalledAsset?
  purchases                RecordingPurchase[]
  entitlements             RecordingEntitlement[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([status, createdAt])
  @@index([primaryPasukId, status])
}

model PasukBoundary {
  id          String    @id @default(cuid())
  recordingId String
  pasukId     String
  startMs     Int
  endMs       Int
  confidence  Float?
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  pasuk       Pasuk     @relation(fields: [pasukId], references: [id], onDelete: Cascade)

  @@unique([recordingId, pasukId])
  @@index([recordingId, startMs])
}

model Vote {
  id          String    @id @default(cuid())
  userId      String
  recordingId String
  type        VoteType
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@unique([userId, recordingId])
  @@index([recordingId, type])
}

model ModerationDecision {
  id          String          @id @default(cuid())
  recordingId String
  moderatorId String
  nextStatus  RecordingStatus
  reason      String?
  createdAt   DateTime        @default(now())
  recording   Recording       @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  moderator   User            @relation("ModeratorActions", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([recordingId, createdAt])
  @@index([moderatorId, createdAt])
}

model ClassGroup {
  id          String               @id @default(cuid())
  name        String
  teacherId   String
  teacher     User                 @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]
  invites     TeacherInvite[]
  assignments PracticeAssignment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([teacherId, createdAt])
}

model ClassEnrollment {
  id        String     @id @default(cuid())
  groupId   String
  studentId String
  group     ClassGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student   User       @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([groupId, studentId])
  @@index([studentId, createdAt])
}

model TeacherInvite {
  id               String              @id @default(cuid())
  teacherId        String
  groupId          String?
  email            String
  token            String              @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime            @default(now())
  teacher          User                @relation("TeacherInvites", fields: [teacherId], references: [id], onDelete: Cascade)
  group            ClassGroup?         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  acceptedByUser   User?               @relation("AcceptedTeacherInvites", fields: [acceptedByUserId], references: [id])
  directLink       TeacherStudentLink?

  @@index([teacherId, createdAt])
  @@index([groupId, createdAt])
  @@index([email, expiresAt])
}

model TeacherStudentLink {
  id        String         @id @default(cuid())
  teacherId String
  studentId String
  inviteId  String?        @unique
  createdAt DateTime       @default(now())
  teacher   User           @relation("DirectTeacherLinks", fields: [teacherId], references: [id], onDelete: Cascade)
  student   User           @relation("DirectStudentLinks", fields: [studentId], references: [id], onDelete: Cascade)
  invite    TeacherInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@unique([teacherId, studentId])
  @@index([studentId, createdAt])
  @@index([teacherId, createdAt])
}

model PracticeAssignment {
  id                  String          @id @default(cuid())
  groupId             String
  recordingId         String
  assignedByTeacherId String
  instructions        String?
  dueAt               DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  group               ClassGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  recording           Recording       @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  assignedByTeacher   User            @relation("TeacherAssignments", fields: [assignedByTeacherId], references: [id], onDelete: Cascade)
  playbackEvents      PlaybackEvent[]

  @@index([groupId, createdAt])
  @@index([recordingId, createdAt])
}

model PlaybackEvent {
  id           String              @id @default(cuid())
  studentId    String
  teacherId    String?
  recordingId  String
  assignmentId String?
  pasukId      String?
  eventType    String
  positionMs   Int?
  durationMs   Int?
  occurredAt   DateTime            @default(now())
  student      User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher      User?               @relation("PlaybackTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  recording    Recording           @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  assignment   PracticeAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  pasuk        Pasuk?              @relation(fields: [pasukId], references: [id], onDelete: SetNull)

  @@index([studentId, occurredAt])
  @@index([teacherId, occurredAt])
  @@index([recordingId, occurredAt])
  @@index([assignmentId, occurredAt])
}

model PaywalledAsset {
  id           String              @id @default(cuid())
  recordingId  String              @unique
  enabled      Boolean             @default(false)
  priceCents   Int?
  currencyCode String?             @default("USD")
  recording    Recording           @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  purchases    RecordingPurchase[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model RevenueShareRule {
  id              String    @id @default(cuid())
  recorderPercent Int
  platformPercent Int
  effectiveFrom   DateTime
  effectiveUntil  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Coupon {
  id              String              @id @default(cuid())
  code            String              @unique
  description     String?
  discountType    DiscountType
  percentOff      Int?
  amountOffCents  Int?
  maxRedemptions  Int?
  redeemBy        DateTime?
  active          Boolean             @default(true)
  createdByUserId String
  createdBy       User                @relation("CouponCreators", fields: [createdByUserId], references: [id], onDelete: Cascade)
  redemptions     CouponRedemption[]
  purchases       RecordingPurchase[]
  teacherAccessSubscriptions TeacherAccessSubscription[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([active, redeemBy])
}

model CouponRedemption {
  id         String             @id @default(cuid())
  couponId   String
  userId     String
  purchaseId String?
  coupon     Coupon             @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase   RecordingPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdAt  DateTime           @default(now())

  @@unique([couponId, userId])
  @@index([userId, createdAt])
}

model RecordingPurchase {
  id               String                @id @default(cuid())
  userId           String
  recordingId      String
  paywalledAssetId String?
  couponId         String?
  currencyCode     String
  baseAmountCents  Int
  discountCents    Int                   @default(0)
  finalAmountCents Int
  status           PurchaseStatus        @default(PENDING)
  completedAt      DateTime?
  metadata         Json?
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording        Recording             @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  paywalledAsset   PaywalledAsset?       @relation(fields: [paywalledAssetId], references: [id], onDelete: SetNull)
  coupon           Coupon?               @relation(fields: [couponId], references: [id], onDelete: SetNull)
  redemptions      CouponRedemption[]
  entitlement      RecordingEntitlement?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([userId, createdAt])
  @@index([recordingId, createdAt])
}

model RecordingEntitlement {
  id          String             @id @default(cuid())
  userId      String
  recordingId String
  purchaseId  String?            @unique
  source      EntitlementSource
  expiresAt   DateTime?
  metadata    Json?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording   Recording          @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  purchase    RecordingPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())

  @@unique([userId, recordingId])
  @@index([recordingId, createdAt])
}

model ContactMessage {
  id         String   @id @default(cuid())
  userId     String?
  name       String
  email      String
  subject    String
  message    String
  contextUrl String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([email, createdAt])
}

model SuperuserNotification {
  id        String                @id @default(cuid())
  channel   NotificationChannel   @default(IN_APP)
  eventType NotificationEventType
  title     String
  body      String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([readAt, createdAt])
  @@index([eventType, createdAt])
}

model TokenizationRule {
  id         String                @id @default(cuid())
  eventType  TokenizationEventType @unique
  tokenDelta Int
  enabled    Boolean               @default(true)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model TokenLedgerEntry {
  id          String                @id @default(cuid())
  recipientId String
  eventType   TokenizationEventType
  sourceType  String
  sourceId    String
  tokenDelta  Int
  metadata    Json?
  recipient   User                  @relation("TokenRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())

  @@index([recipientId, createdAt])
  @@index([eventType, createdAt])
}

model TeacherAccessSubscription {
  id                     String              @id @default(cuid())
  userId                 String              @unique
  status                 TeacherAccessStatus @default(ACTIVE)
  source                 TeacherAccessSource
  priceCents             Int                 @default(0)
  currencyCode           String              @default("USD")
  couponId               String?
  externalCustomerId     String?
  externalSubscriptionId String?
  activatedAt            DateTime            @default(now())
  deactivatedAt          DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon                 Coupon?             @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([source, updatedAt])
}
